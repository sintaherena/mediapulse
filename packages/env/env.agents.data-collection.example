# Port this agent listens on (data-collection: 4001)
PORT=4001 #number #default
# URL endpoint for communicating with agent-data-api
AGENT_DATA_API_URL="http://localhost:8081" # required
# URL of the agent-auth-api service used to verify API keys
AGENT_AUTH_API_URL="http://localhost:8080" # required

# Jina AI API Key for Reader API
JINA_API_KEY= # required

SERPER_API_KEY= # required

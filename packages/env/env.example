# Prisma uses this connection string to connect to the PostgreSQL database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Example: postgresql://postgres:mypassword@localhost:5432/mydb?schema=public
DATABASE_URL=postgresql://mediapulse:mediapulse@localhost:5432/mediapulse?schema=public # required
DATABASE_CERT_BASE64=
# URL endpoint for communicating with agent-data-api
AGENT_DATA_API_URL="http://localhost:3000"
AGENT_API_KEY=

# Temporary admin credentials
TEMP_ADMIN_USERNAME=admin # required
TEMP_ADMIN_PASSWORD=adminadmin # required

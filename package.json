{
  "name": "mediapulse",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "deploy": "turbo deploy",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "netlify-cli": "^23.13.3",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "speed-docs": "^0.0.22",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "@tailwindcss/oxide",
      "bcrypt",
      "core-js-pure",
      "esbuild",
      "netlify-cli",
      "prisma",
      "sharp",
      "unix-dgram"
    ]
  }
}

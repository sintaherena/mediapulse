# URL endpoint for communicating with agent-data-api
AGENT_DATA_API_URL="http://localhost:3000" # required
# URL of the agent-auth-api service used to verify API keys
AGENT_AUTH_API_URL="http://localhost:8080" # required

# OpenAI API Key for content generation
OPENAI_API_KEY= # required

# OpenAI model to use for content generation
OPENAI_MODEL="gpt-4o-mini" # required

# Temporary admin credentials
TEMP_ADMIN_USERNAME=admin # required
TEMP_ADMIN_PASSWORD=adminadmin # required

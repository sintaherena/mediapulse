# URL endpoint for communicating with agent-data-api
AGENT_DATA_API_URL="http://localhost:3000" # required
# URL of the agent-auth-api service used to verify API keys
AGENT_AUTH_API_URL="http://localhost:8080" # required

# Resend sender email
RESEND_SENDER=abc@hyperjump.tech # required

# Resend API Key
RESEND_API_KEY=abc-xyz # required

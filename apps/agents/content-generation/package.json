{
  "type": "module",
  "name": "content-generation-agent",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../../packages/env/.env.agents.content-generation -- bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outfile=./dist/server.js --target=bun",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@workspace/agent-auth-client": "workspace:*",
    "@workspace/agent-types": "workspace:*",
    "@workspace/env": "workspace:*",
    "@workspace/logger": "workspace:*",
    "got": "catalog:",
    "hono": "catalog:",
    "hono-pino": "catalog:",
    "openai": "^6.21.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "dotenv-cli": "catalog:",
    "vitest": "^4.0.18"
  }
}
